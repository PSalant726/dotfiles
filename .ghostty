app-notifications = config-reload,no-clipboard-copy
notify-on-command-finish = never
notify-on-command-finish-action = no-bell,notify

auto-update = check
auto-update-channel = stable

font-family = JetBrainsMono Nerd Font Mono
font-family = Hack Nerd Font Mono
font-family-bold = JetBrainsMono NFM Bold
font-family-bold = Hack Nerd Font Mono Bold
font-family-bold-italic = JetBrainsMono NFM Bold Italic
font-family-bold-italic = Hack Nerd Font Mono Bold Italic
font-family-italic = JetBrainsMono NFM Italic
font-family-italic = Hack Nerd Font Mono Italic
font-size = 14

fullscreen = false
maximize = true
theme = Abernathy
unfocused-split-opacity = 0.3
window-padding-x = 10
